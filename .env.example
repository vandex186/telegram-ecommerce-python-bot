# Copy to .env and fill in real values:
#   cp .env.example .env
#
# ── NEW BOT via @BotFather ─────────────────────────────────────────────
# 1. Open Telegram → @BotFather → /newbot
# 2. Display name: TetraHydro
# 3. Username: TetraHydroGuild_bot  →  https://t.me/TetraHydroGuild_bot
# 4. Copy the HTTP API token BotFather sends (format: 123456789:ABCdef...)
# 5. Paste below as TELEGRAM_BOT_TOKEN (replace only this line in existing .env)
#
# Replacing @streettrader_bot? Back up .env first, stop old bot (Ctrl+C),
# add @TetraHydroGuild_bot as admin to catalog channel (STOCK_CHANNEL_ID), then ./run.sh
# Full steps (Russian): NEW_BOT_SETUP.md

# Required — token from @BotFather (/newbot)
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Required for catalog — private channel ID (new bot must be channel admin)
# Get ID by forwarding a channel post to @userinfobot or from bot logs
STOCK_CHANNEL_ID=-1001234567890

# Your Telegram user ID (admin commands + admin panel)
ADMIN_USER_ID=123456789

# Optional shop branding
SUPPORT_HANDLE=@your_support_handle
CURRENCY=$
SHOP_IMAGE=tetrahydroguild.png

# Catalog sync windows (optional)
# CATALOG_SYNC_POST_LIMIT — how many newest cached channel posts to re-parse on /sync_catalog
# CATALOG_ACTIVE_CARD_LOOKBACK — how many recent product cards to search when matching a name/slug
CATALOG_SYNC_POST_LIMIT=100
CATALOG_ACTIVE_CARD_LOOKBACK=20
# Re-run full catalog sync every N minutes while bot is running (0 = off)
CATALOG_SYNC_INTERVAL_MINUTES=5

# Payment is OFF for now (catalog + cart only). Leave as false.
ENABLE_PAYMENTS=false
ENABLE_TELEGRAM_PAY=false
PAYMENT_PROVIDER_TOKEN=
PAYMENT_CURRENCY=USD
OXAPAY_API_KEY=
OXAPAY_SANDBOX=true
