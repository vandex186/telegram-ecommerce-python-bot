# Template for switching to @TetraHydroGuild_bot (replace token in existing .env).
#
# Do NOT overwrite .env blindly — back up first:
#     cp .env .env.backup.$(date +%Y%m%d)
#
# BotFather: /newbot ? display name TetraHydro ? username TetraHydroGuild_bot
# Bot link: https://t.me/TetraHydroGuild_bot
#
# Then edit .env and replace ONLY the line below with the new token from @BotFather.
# Keep STOCK_CHANNEL_ID, ADMIN_USER_ID, and other settings unless you also change
# channel or admin account.
#
# After updating .env:
#   1. Stop the old bot process (@streettrader_bot) if it runs from this folder
#   2. Add @TetraHydroGuild_bot as admin to your private catalog channel (STOCK_CHANNEL_ID)
#   3. Run: ./run.sh
#
# Full steps (Russian): NEW_BOT_SETUP.md

TELEGRAM_BOT_TOKEN=YOUR_NEW_BOT_TOKEN_HERE

# Leave unchanged unless you use a different channel or admin:
# STOCK_CHANNEL_ID=-1001234567890
# ADMIN_USER_ID=123456789
